# ─── Node.js ──────────────────────────────────────────────────────────────────
node_modules/
dist/
build/
.next/
.nuxt/
out/
.vercel/
.turbo/
*.tsbuildinfo

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
.venv/
venv/
.uv/
dist/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ─── Go ───────────────────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# ─── Rust ─────────────────────────────────────────────────────────────────────
target/
Cargo.lock   # Only ignore for libraries, not binaries — remove this line for binaries

# ─── Docker ───────────────────────────────────────────────────────────────────
infra/docker-compose.override.yml

# ─── IDE / Editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Testing ──────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Terraform ────────────────────────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example

# ─── Claude Code ──────────────────────────────────────────────────────────────
