{
  "name": "skillbridge",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "lint": "pnpm -r run --if-present lint",
    "type-check": "pnpm -r run --if-present type-check",
    "test": "pnpm -r run --if-present test",
    "test:unit": "pnpm -r run --if-present test:unit",
    "test:e2e": "pnpm -r run --if-present test:e2e",
    "build": "pnpm -r run --if-present build"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "!(packages/schema/generated/**)*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!(packages/schema/generated/**)*.{json,md,yaml,yml}": [
      "prettier --write"
    ],
    "!(packages/schema/generated/**)*.py": [
      "ruff check --fix",
      "ruff format"
    ],
    "*.go": [
      "gofmt -w"
    ],
    "*.rs": [
      "rustfmt"
    ]
  },
  "dependencies": {
    "@composio/core": "^0.6.4"
  }
}
