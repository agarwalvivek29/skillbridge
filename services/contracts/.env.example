# Environment variables for the contracts service
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# Keep this file up to date with placeholder (non-functional) values.

# ─── Solana RPC URL ─────────────────────────────────────────────────────────
# Local: http://127.0.0.1:8899 (solana-test-validator)
# Devnet: https://api.devnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com — requires explicit human approval
SOLANA_RPC_URL=http://127.0.0.1:8899

# ─── Anchor Wallet ──────────────────────────────────────────────────────────
# Path to the deployer keypair JSON file
# Generate with: solana-keygen new -o ~/.config/solana/devnet.json
ANCHOR_WALLET=~/.config/solana/id.json

# ─── Deployed Program ID (filled after deployment) ─────────────────────────
ESCROW_PROGRAM_ID=

# ─── Platform Fee Recipient ─────────────────────────────────────────────────
# Public key that receives the 5% platform fee on each milestone payout
# Use a multisig wallet for production
FEE_RECIPIENT=replace-me-with-platform-fee-wallet-pubkey
