# Environment variables for the contracts service
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# Keep this file up to date with placeholder (non-functional) values.

# ─── Deployer ────────────────────────────────────────────────────────────────
# Private key of the deployer wallet (hex, no 0x prefix)
# Generate a fresh key for testnet; use a hardware wallet for mainnet
PRIVATE_KEY=replace-me-with-deployer-private-key-hex

# ─── Network RPC URLs ────────────────────────────────────────────────────────
# Base Sepolia (testnet)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base Mainnet — ⚠️  Requires explicit human approval before use
BASE_RPC_URL=https://mainnet.base.org

# ─── Contract Verification ───────────────────────────────────────────────────
# Basescan API key for contract verification
# Get from https://basescan.org/myapikey
BASESCAN_API_KEY=replace-me-with-basescan-api-key

# ─── Platform Fee Recipient ───────────────────────────────────────────────────
# Address that receives the 5% platform fee on each milestone payout
# Use a multisig wallet for production (e.g. Safe on Base)
FEE_RECIPIENT=replace-me-with-platform-fee-wallet-address

# ─── Deployed Contract Addresses (filled after deployment) ──────────────────
# Base Sepolia
ESCROW_FACTORY_ADDRESS_SEPOLIA=

# Base Mainnet (set only after human-approved mainnet deploy)
ESCROW_FACTORY_ADDRESS_MAINNET=
