# Environment variables for services/contracts (Foundry / deployment tooling)
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# Keep this file up to date with placeholder (non-functional) values.

# ─── Deployment wallet ────────────────────────────────────────────────────────
# Private key of the deployer wallet (used by forge script --broadcast)
# Generate a dedicated deployment wallet — never use a wallet that holds mainnet funds.
PRIVATE_KEY=replace-me-with-deployer-private-key

# ─── RPC endpoints ────────────────────────────────────────────────────────────
# Base Sepolia (testnet) — used for dev/staging
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Base Mainnet — REQUIRES explicit human approval before any script runs against this
BASE_RPC_URL=https://mainnet.base.org

# ─── Contract verification ────────────────────────────────────────────────────
# Basescan API key (https://basescan.org/myapikey)
BASESCAN_API_KEY=replace-me-with-basescan-api-key

# ─── Mainnet deployment guard ────────────────────────────────────────────────
# Set to "true" ONLY when you are intentionally deploying to Base Mainnet.
# Requires explicit human approval. Defaults to "false".
ALLOW_MAINNET=false

# ─── Deployed contract addresses (filled in post-deployment) ─────────────────
# Set these after deploying EscrowFactory. The api service reads ESCROW_FACTORY_ADDRESS.
ESCROW_FACTORY_ADDRESS=

# ─── Auth (REQUIRED — all services) ──────────────────────────────────────────
# Shared JWT secret used to sign and verify tokens across all services.
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-32-char-minimum-random-string

# Shared API key for service-to-service (BE<->BE) communication.
API_KEY=replace-me-with-a-secure-random-api-key
