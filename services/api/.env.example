# Environment variables for services/api
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# Keep this file up to date with placeholder (non-functional) values.

# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
PORT=8000
LOG_LEVEL=info

# ─── Database ────────────────────────────────────────────────────────────────
# Async PostgreSQL connection string (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/skillbridge

# ─── Cache / Queue ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (REQUIRED — all services) ──────────────────────────────────────────
# Shared JWT secret used to sign and verify tokens across all services.
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-32-char-minimum-random-string

# JWT expiry in seconds (default: 1 hour)
JWT_EXPIRY_SECONDS=3600

# Domain used for SIWE (EIP-4361) message verification — must match the frontend hostname
SIWE_DOMAIN=skillbridge.agarwalvivek.com

# Shared API key for service-to-service (BE↔BE) communication.
# Set the same value in all services. Generate with: openssl rand -hex 32
API_KEY=replace-me-with-a-secure-random-api-key

# ─── Blockchain ───────────────────────────────────────────────────────────────
# Base L2 RPC endpoint
BASE_RPC_URL=https://sepolia.base.org
# Deployed EscrowFactory contract address (set after deployment)
ESCROW_FACTORY_ADDRESS=

# ─── AWS / S3 ─────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
S3_BUCKET=skillbridge-dev
# Presigned URL expiry in seconds (default: 300 = 5 minutes)
S3_PRESIGNED_URL_EXPIRY_SECONDS=300
