# Environment variables for api service
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# Keep this file up to date with placeholder (non-functional) values.

# ─── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL async connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://skillbridge:password@localhost:5432/skillbridge

# ─── Cache / Queue ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (REQUIRED — all services) ──────────────────────────────────────────
# Shared JWT secret used to sign and verify tokens across all services.
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-32-char-minimum-random-string

# JWT expiry in seconds (default: 1 hour)
JWT_EXPIRY_SECONDS=3600

# Shared API key for service-to-service (BE↔BE) communication.
# Set the same value in all services. Generate with: openssl rand -hex 32
API_KEY=replace-me-with-a-secure-random-api-key

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
# Used for portfolio file upload presigned URLs
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
S3_BUCKET=skillbridge-uploads
S3_PRESIGN_EXPIRY_SECONDS=300

# ─── Base L2 Blockchain ──────────────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org
ESCROW_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
