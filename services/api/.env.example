# Environment variables for services/api
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# Keep this file up to date with placeholder (non-functional) values.

# ─── Application ─────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────────────────
# Async PostgreSQL URL (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/skillbridge

# ─── Auth (REQUIRED — all services) ──────────────────────────────────────────
# Shared JWT secret used to sign and verify tokens across all services.
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-32-char-minimum-random-string-here

# JWT expiry in seconds (default: 1 hour)
JWT_EXPIRY_SECONDS=3600

# Shared API key for service-to-service (BE↔BE) communication.
# Set the same value in all services. Generate with: openssl rand -hex 16
API_KEY=replace-me-16-chars

# ─── SIWE (Sign-In with Ethereum) ────────────────────────────────────────────
# Domain used in SIWE message verification (must match frontend origin)
SIWE_DOMAIN=localhost

# Expected EVM chain ID: 8453 = Base mainnet, 84532 = Base Sepolia testnet
SIWE_CHAIN_ID=84532

# SIWE nonce validity window in seconds (default: 5 minutes)
NONCE_TTL_SECONDS=300
