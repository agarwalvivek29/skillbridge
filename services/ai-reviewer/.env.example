# Environment variables for [SERVICE_NAME]
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# Keep this file up to date with placeholder (non-functional) values.

# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# MongoDB
# MONGO_URI=mongodb://user:password@localhost:27017/dbname

# ─── Cache / Queue ───────────────────────────────────────────────────────────
# Redis
# REDIS_URL=redis://localhost:6379

# Kafka
# KAFKA_BROKERS=localhost:9092
# KAFKA_GROUP_ID=[service_name]-group

# RabbitMQ
# RABBITMQ_URL=amqp://user:password@localhost:5672

# ─── Auth (REQUIRED — all services) ──────────────────────────────────────────
# Shared JWT secret used to sign and verify tokens across all services.
# Minimum 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-32-char-minimum-random-string

# JWT expiry in seconds (default: 1 hour)
JWT_EXPIRY_SECONDS=3600

# Shared API key for service-to-service (BE↔BE) communication.
# Set the same value in all services. Generate with: openssl rand -hex 32
API_KEY=replace-me-with-a-secure-random-api-key

# ─── External services ─────��─────────────────────────────────────────────────
# Add API keys and external service URLs here
# SOME_API_KEY=replace-me

# ─── AWS (if needed) ─────────────────────────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=replace-me
# AWS_SECRET_ACCESS_KEY=replace-me
