# Environment variables for services/ai-reviewer (openreview)
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-placeholder

# ─── GitHub App ───────────────────────────────────────────────────────────────
GITHUB_APP_ID=placeholder
GITHUB_APP_INSTALLATION_ID=placeholder
# Private key — replace newlines with \n when setting as a single-line string
GITHUB_APP_PRIVATE_KEY=placeholder
GITHUB_APP_WEBHOOK_SECRET=replace-me-webhook-secret
